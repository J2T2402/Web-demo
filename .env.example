# ====== Cấu hình deploy (docker-compose) — sao chép thành .env ======
# .env này dùng cho compose ở thư mục gốc. KHÔNG commit .env thật.

# --- PostgreSQL ---
POSTGRES_USER=webevent
POSTGRES_PASSWORD=doi-thanh-mat-khau-manh
POSTGRES_DB=webevent

# --- App ---
PORT=3000
# Bí mật ký JWT đăng nhập admin (chuỗi ngẫu nhiên dài).
JWT_SECRET=doi-thanh-chuoi-ngau-nhien-that-dai
# Khóa mã hóa PII (Họ tên + SĐT) — đặt bí mật, độ dài >= 32 ký tự.
ENCRYPTION_KEY=doi-thanh-khoa-ma-hoa-bi-mat-toi-thieu-32-ky-tu
# Tài khoản admin khởi tạo (server tự seed lần đầu).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=doi-thanh-mat-khau-admin-manh
