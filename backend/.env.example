# ====== Backend (local dev) ======
# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit .env.

PORT=3000

# Kết nối PostgreSQL. Local dev có thể trỏ tới Postgres chạy trên máy/Docker.
DATABASE_URL=postgresql://webevent:change-me@localhost:5432/webevent

# Bí mật ký JWT đăng nhập admin (đặt chuỗi ngẫu nhiên dài).
JWT_SECRET=change-me-very-long-random-string

# Khóa mã hóa PII (Họ tên + SĐT). Dùng chuỗi bí mật đủ dài (>= 32 ký tự).
ENCRYPTION_KEY=change-me-encryption-secret-at-least-32-chars

# Tài khoản admin khởi tạo (tự seed lần đầu chạy server).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
